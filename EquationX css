body{
  font-family:Arial,sans-serif;
  background:#1e3c72;
  color:#fff;
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
  margin:0;
}
.game{
  background:#ffffff20;
  padding:20px;
  border-radius:10px;
  text-align:center;
}
input,button{
  padding:10px;
  margin:8px;
  border:none;
  border-radius:5px;
}
button{
  background:#00c853;
  color:#fff;
  cursor:pointer;
}
button:hover{
  background:#009624;
}
#result{
  margin-top:10px;
  font-weight:bold;
}
